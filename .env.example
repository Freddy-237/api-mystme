# ============================================
# MystMe Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.

# --- Server ---
PORT=5000
NODE_ENV=development
JWT_SECRET=your-jwt-secret-here

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mystme
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=mystme
DB_SSL=false

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Cloudinary (required for media uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Firebase (required for push notifications) ---
# JSON string of service-account credentials
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- IAP Receipt Validation (required for in-app purchases) ---
# Apple: shared secret from App Store Connect
APPLE_SHARED_SECRET=
# Google: JSON string of Google Play service-account credentials
GOOGLE_SERVICE_ACCOUNT=
GOOGLE_PACKAGE_NAME=com.mystme.app

# --- Email OTP (optional but recommended for phase 2) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="MystMe <no-reply@mystme.app>"

# --- Brevo API (optional alternative to SMTP) ---
# If BREVO_API_KEY is set, backend tries Brevo API first, then SMTP fallback.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=MystMe

# --- Optional ---
AUTH_COOKIE_NAME=mystme_token
AUTH_COOKIE_DOMAIN=
CSRF_COOKIE_NAME=mystme_csrf
CSRF_HEADER_NAME=x-csrf-token
LOG_LEVEL=info

# --- Monitoring (optional) ---
# Sentry DSN for error tracking
SENTRY_DSN=
